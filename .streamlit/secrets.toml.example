# Streamlit secrets template.
# On Streamlit Community Cloud, paste the contents of this file into
# Settings -> Secrets. For local use, copy to .streamlit/secrets.toml and fill
# in real values. NEVER commit the real secrets.toml.
#
# Access in code with: st.secrets["section"]["key"]

# Example: optional simple access password for the app.
# app_password = "change-me"

# Example: external service credentials (if you add integrations later).
# [database]
# url = "postgresql://user:password@host:5432/dbname"

# [smtp]
# host = "smtp.example.com"
# port = 587
# user = "noreply@example.com"
# password = "change-me"
