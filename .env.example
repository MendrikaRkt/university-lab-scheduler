# Environment variables for the University Lab Scheduler.
# Copy this file to .env and adjust the values. NEVER commit the real .env.
#   cp .env.example .env

# --- Application -------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Host port to expose the app on (mapped to the container's 8501).
APP_PORT=8501

# --- Streamlit server --------------------------------------------------------
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# --- Solver overrides (optional) ---------------------------------------------
# These are read from config/config.yaml by default. Uncomment to override.
# SOLVER_TIME_LIMIT_SECONDS=300
# SOLVER_NUM_WORKERS=8

# --- Secrets (optional) ------------------------------------------------------
# Prefer .streamlit/secrets.toml for Streamlit-native secrets. Use these only
# if you wire them into the application yourself.
# APP_PASSWORD=change-me
