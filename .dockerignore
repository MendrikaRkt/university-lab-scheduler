# Version control
.git
.gitignore

# Python caches and build artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test / tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Runtime outputs (must not be baked into the image)
logs/
outputs/
reports/
data_clean/*.csv

# Local environment and secrets
.env
.env.*
!.env.example
.streamlit/secrets.toml

# Editors / OS
.vscode/
.idea/
.DS_Store

# CI and docs not needed at runtime
.github/
DEPLOYMENT.md
SECURITY.md

# Platform-specific
.abacus.donotdelete
